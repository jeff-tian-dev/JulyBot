# Discord
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_GUILD_ID=your_guild_id_here

# Bot mode: "full" (default) or "twitter" (Twitter stalker commands only)
BOT_MODE=full

# Clash of Clans API
COC_API_TOKEN=your_coc_api_token_here
COC_API_BASE_URL=https://api.clashofclans.com/v1

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/cocbot

# Base Finder
BASE_IMAGE_DIR=./data/bases
BASE_CACHE_SIZE=750
YOUTUBE_CHANNEL_IDS=UCxxxxxx,UCyyyyyy

# Scheduler
LEGEND_POLL_INTERVAL_MINUTES=60
CACHE_REFRESH_INTERVAL_HOURS=24

# Twitter Stalker (twitterapi.io webhooks)
TWITTERAPI_IO_KEY=your_twitterapi_io_key_here
TWITTER_WEBHOOK_HOST=0.0.0.0
TWITTER_WEBHOOK_PORT=8080
TWITTER_WEBHOOK_PATH=/webhooks/twitter
TWITTER_FILTER_INTERVAL_SECONDS=60
TWITTER_FILTER_TAG=julybot-stalk
# Comma-separated Discord role IDs allowed to use Twitter commands.
# If empty, falls back to requiring Manage Server permission.
TWITTER_ALLOWED_ROLE_IDS=
