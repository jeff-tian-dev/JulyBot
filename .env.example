# Discord
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_GUILD_ID=your_guild_id_here

# Clash of Clans API (whitelist this Mac Studio's public IP at developer.clashofclans.com)
COC_API_TOKEN=your_coc_api_token_here
# If your public IP changes, whitelist RoyaleAPI's static IP (45.79.218.79) in the
# developer portal instead and route through their proxy by setting:
#   COC_API_BASE_URL=https://cocproxy.royaleapi.dev/v1
COC_API_BASE_URL=https://api.clashofclans.com/v1
# Clan-watch (roster leave/rejoin alerts + absence tracking). "In" = in ANY of
# the family clans below; "out" = in none. List every family clan tag, comma-
# separated, no '#' (the '#' is a comment char in .env). Leave empty to disable.
COC_FAMILY_CLAN_TAGS=
# Optional single main-clan tag; merged into the family above (back-compat).
COC_CLAN_TAG=
# Channel that clan-watch leave/rejoin alerts post to (defaults to the hardcoded id).
CLAN_WATCH_CHANNEL_ID=1528897151625592993
CLAN_WATCH_POLL_INTERVAL_MINUTES=10

# Database — Supabase (hosted Postgres + pgvector)
# Use the "Session pooler" connection string from your Supabase project:
#   Dashboard -> Project Settings -> Database -> Connection string -> "Session pooler"
# It is IPv4-compatible and safe for a long-lived asyncpg pool. Keep ?sslmode=require.
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres?sslmode=require

# Base Finder
BASE_IMAGE_DIR=/Users/jefftian/JulyBot/data/bases
BASE_CACHE_SIZE=750
YOUTUBE_CHANNEL_IDS=UCxxxxxx,UCyyyyyy

# Scheduler
LEGEND_POLL_INTERVAL_MINUTES=60
CACHE_REFRESH_INTERVAL_HOURS=24

# X monitor (optional — leave X_COOKIES empty to disable; TWITTER_* names still work)
X_COOKIES=
X_SESSION_NAME=julybot_x
X_POLL_INTERVAL_MINUTES=10
X_PING_ROLE_ID=
# Suppress repeat role pings: after a ping, new posts within this many hours post silently.
X_PING_COOLDOWN_HOURS=3

# YouTube feed tracker
YOUTUBE_FEED_POLL_INTERVAL_MINUTES=10
YOUTUBE_PING_ROLE_ID=1508359179440750602
# Suppress repeat role pings: after a ping, new videos within this many hours post silently.
YOUTUBE_PING_COOLDOWN_HOURS=3

# Moderation
MOD_LOG_CHANNEL_ID=1514111681222148219
