# Copy to /opt/julybot/.env on the VM.

BOT_MODE=twitter

# Discord — https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_GUILD_ID=your_guild_id_here

# Supabase — Project Settings → Database → Connection string (Session pooler, port 6543)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# twitterapi.io
TWITTERAPI_IO_KEY=your_twitterapi_io_key_here
TWITTER_WEBHOOK_HOST=0.0.0.0
TWITTER_WEBHOOK_PORT=8080
TWITTER_WEBHOOK_PATH=/webhooks/twitter
TWITTER_FILTER_INTERVAL_SECONDS=60
TWITTER_FILTER_TAG=julybot-stalk

COC_API_TOKEN=unused
